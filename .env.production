# Production overrides for `npm run build` (picked up by Create React App).
# This file is committed on purpose: Netlify builds off the repo, so baking the
# production backend URL here makes every deploy point at the right host without
# depending on dashboard env-var config. .env.production.local (git-ignored)
# still wins if a developer needs a local override.

REACT_APP_BACKEND_URL=https://whalehub-server-28ipy.ondigitalocean.app
REACT_APP_BACKEND_API_URL=https://whalehub-server-28ipy.ondigitalocean.app

# Soroban RPC — primary is Validation Cloud (dedicated endpoint, no shared
# rate-limit bucket); fallback is gateway.fm (used automatically by
# SorobanService when the primary 429s / 5xxs).
# NOTE: REACT_APP_* values are baked into the public JS bundle at build time,
# so this key is visible to any user via DevTools. That is acceptable for a
# rate-limited read-RPC key; if it ever needs to be hidden, proxy through the
# backend instead.
REACT_APP_SOROBAN_RPC_URL=https://mainnet.stellar.validationcloud.io/v1/BeJBH07q3tZsFGc9hmfm-8SdGnT9_z2881Uw92tvQic
REACT_APP_SOROBAN_FALLBACK_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm
